# CaptionAI Finder - ortam degiskenleri ornegi
# Local test: bu dosyayi .env olarak kopyalayip degerleri doldur, sonra
#   `set -a; source .env; set +a; python app.py`
# Server (Fly.io): GIZLI olanlari `fly secrets set ...` ile gir (fly.toml'a YAZMA).

# --- Gizli (secrets olarak gir) ---
# Birden fazla ise virgul veya yeni satirla ayir.
APIFY_TOKENS=apify_token_1,apify_token_2
GROQ_KEYS=groq_key_1,groq_key_2
# Email hesaplari JSON dizi olarak (Gmail UYGULAMA sifresi, normal sifre degil):
EMAIL_ACCOUNTS=[{"email":"sen@gmail.com","password":"uygulama_sifresi","from_name":"Adin"}]

# --- Ayarlar (fly.toml [env]'de de olabilir) ---
HOST=0.0.0.0
PORT=8080
DATA_DIR=/data
AUTOSTART=1
REQUIRE_EMAIL=1
STRICT_COUNTRY=1
COUNTRIES=Turkiye
HASHTAGS=yemektarifi, gunlukvlog, kombin, gymtok, gezilecekyerler
MIN_FOLLOWERS=3000
MAX_FOLLOWERS=80000
TARGET_COUNT=60
IDLE_SLEEP=3600
DAILY_LIMIT=30
EMAIL_SUBJECT=videolarin icin ufak bir sey
SITE_URL=thecaptionai.com
