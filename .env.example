# ==== CaptionAI Finder - Autopilot ayarlari (email-only, DM YOK) ====
# Bunlari server'da (Fly.io secrets) ya da local'de .env olarak ver.

# Apify API token(lar)i - virgulle coklu girebilirsin (biri bitince digeri)
APIFY_TOKENS=apify_api_xxx,apify_api_yyy

# Groq API key(ler)i - console.groq.com/keys
GROQ_KEYS=gsk_xxx,gsk_yyy

# Gonderen Gmail hesaplari - JSON dizi. Sifre = Gmail UYGULAMA SIFRESI.
# myaccount.google.com/apppasswords
EMAIL_ACCOUNTS=[{"email":"you@gmail.com","password":"abcd efgh ijkl mnop","from_name":"Senin Adin"}]

# Aranacak hashtag'ler (virgulle). Cok hashtag ver -> her tur rotasyonla farkli havuz.
HASHTAGS=yemektarifi,evyemekleri,gunlukvlog,kombin,makyaj,gymtok,gezilecekyerler

# Hedef ulke/dil (virgulle). Bos = filtre yok.
COUNTRIES=Turkiye

# Filtreler
MIN_FOLLOWERS=3000
MAX_FOLLOWERS=80000
TARGET_PER_ROUND=40
HASHTAGS_PER_ROUND=3

# Email
EMAIL_SUBJECT=videolarin icin ufak bir sey
DAILY_LIMIT_PER_ACCOUNT=30
SITE_URL=thecaptionai.com

# Zamanlama (saniye)
ROUND_INTERVAL_SECONDS=900
IDLE_INTERVAL_SECONDS=3600

# DB yolu (Fly volume). Local'de bos birakabilirsin -> finder_crm.db
DB_FILE=/data/finder_crm.db
